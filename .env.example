# Environment variables for PRODUCTION (config.settings.production).
#
# This is a manifest, not a file the app loads — the app reads os.environ, and
# on Railway you set these in the service's Variables tab. Copy real values
# there; never commit a filled-in .env (it's gitignored). Dev/test (dev.py) need
# none of these.
#
# Legend:  [AUTO] injected by Railway — do NOT set by hand.
#          [DEV]  you supply the value.

# --- Django core ----------------------------------------------------------
# Tell Django to use production settings (set this in Railway for every command,
# incl. the build, or collectstatic runs under the wrong settings).
DJANGO_SETTINGS_MODULE=config.settings.production            # [DEV]

# Fresh production secret key — NOT the dev one. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=replace-with-a-freshly-generated-key             # [DEV]

# Comma-separated hostnames Django will serve (no scheme). Include the apex, www,
# and the temporary Railway subdomain during setup.
ALLOWED_HOSTS=childrenlearning.org,www.childrenlearning.org,<project>.up.railway.app   # [DEV]

# Comma-separated origins for CSRF — WITH scheme (https://). Apex + www.
CSRF_TRUSTED_ORIGINS=https://childrenlearning.org,https://www.childrenlearning.org     # [DEV]

# Absolute base URL for Wagtail admin emails (password-reset links). No trailing
# slash, no /admin.
WAGTAILADMIN_BASE_URL=https://childrenlearning.org          # [DEV]

# --- Database -------------------------------------------------------------
# Postgres connection string. The Railway Postgres plugin injects this; never
# set it yourself.
DATABASE_URL=postgresql://...                               # [AUTO]

# --- App server -----------------------------------------------------------
# Port gunicorn binds. Railway injects it; the start command reads $PORT.
PORT=8080                                                   # [AUTO]

# --- Media: Cloudflare R2 (S3-compatible) ---------------------------------
# R2 S3 endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # [DEV]
R2_ACCESS_KEY_ID=<r2-access-key-id>                         # [DEV]
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>                 # [DEV]
R2_BUCKET_NAME=childrenlearning-media                       # [DEV]
# Custom domain that serves the bucket; media URLs are built from it.
R2_CUSTOM_DOMAIN=media.childrenlearning.org                 # [DEV]

# --- Email: SMTP (Migadu) for admin password reset ------------------------
EMAIL_HOST=smtp.migadu.com                                  # [DEV]
EMAIL_PORT=587                                              # [DEV]
EMAIL_HOST_USER=no-reply@childrenlearning.org               # [DEV]
EMAIL_HOST_PASSWORD=<migadu-mailbox-password>               # [DEV]
EMAIL_USE_TLS=True                                          # [DEV]  (STARTTLS on 587)
EMAIL_USE_SSL=False                                         # [DEV]  (set True + port 465 for implicit TLS instead)
DEFAULT_FROM_EMAIL=Komunitas Anak Belajar <no-reply@childrenlearning.org>   # [DEV]
